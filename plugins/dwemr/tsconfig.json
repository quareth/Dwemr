{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["index.ts", "src/**/*.ts", "install-packs.ts"],
  "exclude": ["node_modules", "../dev/tests"]
}
